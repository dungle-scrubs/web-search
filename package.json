{
  "name": "web-search",
  "version": "0.3.0",
  "description": "Web search CLI and library: Brave with Serper fallback, normalized SERP results.",
  "type": "module",
  "license": "MIT",
  "author": "Kevin Frilot <kevin@dungle-scrubs.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dungle-scrubs/web-search.git"
  },
  "bugs": {
    "url": "https://github.com/dungle-scrubs/web-search/issues"
  },
  "homepage": "https://github.com/dungle-scrubs/web-search#readme",
  "keywords": [
    "web-search",
    "brave-search",
    "serper",
    "serp",
    "search-engine",
    "cli",
    "effect",
    "effect-ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "web-search": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "prepare": "lefthook install || true && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "dependencies": {
    "commander": "^15.0.0",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
